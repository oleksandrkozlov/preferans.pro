<!doctype html>
<html lang="en-us">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, minimum-scale=1, user-scalable=no"/>
    <title>Preferans</title>
    <style>
      @font-face {
        font-family: "PreferansClient";
        src: url("resources/fonts/DejaVuSans.ttf") format("truetype");
        font-display: swap;
      }
      html, body {
        width: 100%;
        height: 100%;
      }
      body {
        margin: 0;
        background-color: #282a36;
        overflow: hidden;
      }
      #loading-screen {
        position: fixed;
        inset: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #282a36;
        color: #f8f8f2;
        transition: opacity 180ms ease-out, visibility 180ms ease-out;
      }
      body.game-ready #loading-screen {
        opacity: 0;
        visibility: hidden;
      }
      .loading-panel {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 18px;
        padding: 24px 28px;
      }
      .loading-title {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        max-width: 100%;
        font-family: "PreferansClient", ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
        font-size: 42px;
      }
      .loading-title-top {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        gap: 4px;
      }
      .loading-title-main {
        position: relative;
        line-height: 1;
        font-weight: 400;
        text-transform: uppercase;
      }
      .loading-title-main-shadow,
      .loading-title-main-text {
        display: block;
        line-height: 1;
      }
      .loading-title-main-shadow {
        position: absolute;
        top: 2px;
        left: 2px;
        color: #605482;
        pointer-events: none;
      }
      .loading-title-main-text {
        position: relative;
        color: #f8f8f8;
      }
      .loading-title-pro-wrap {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
        margin-top: 2px;
      }
      .loading-title-pro {
        color: #ffb86c;
        font-size: 0.42em;
        line-height: 1;
        letter-spacing: 0.05em;
        font-weight: 400;
        text-transform: uppercase;
        text-shadow: 0.5px 0.5px 0 #705d51;
      }
      .loading-title-pro-line {
        width: calc(100% + 2px);
        height: 2px;
        margin-left: 0;
        background: #ffb86c;
        transform: rotate(-6deg);
        transform-origin: left center;
        opacity: 0.85;
        border-radius: 999px;
      }
      .loading-spinner {
        width: 104px;
        height: 104px;
        border: 8px solid rgba(248, 248, 242, 0.18);
        border-top-color: #bd93f9;
        border-radius: 50%;
        animation: loading-spin 900ms linear infinite;
        box-shadow: 0 0 22px rgba(189, 147, 249, 0.22);
      }
      .loading-status {
        min-height: 1.2em;
        font: 400 14px/1.4 sans-serif;
        color: rgba(248, 248, 242, 0.74);
      }
      @keyframes loading-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .emscripten {
        position: absolute;
        top: 0px;
        left: 0px;
        margin: 0px;
        border: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        display: block;
        image-rendering: optimizeSpeed;
        image-rendering: -moz-crisp-edges;
        image-rendering: -o-crisp-edges;
        image-rendering: -webkit-optimize-contrast;
        image-rendering: optimize-contrast;
        image-rendering: crisp-edges;
        image-rendering: pixelated;
        -ms-interpolation-mode: nearest-neighbor;
      }
    </style>
  </head>
  <body>
    <div id="loading-screen" aria-live="polite">
      <div class="loading-panel">
        <div class="loading-title" aria-label="Preferans Pro">
          <div class="loading-title-top">
            <span class="loading-title-main">
              <span class="loading-title-main-shadow" aria-hidden="true" id="loading-title-main-shadow">PREFERANS</span>
              <span class="loading-title-main-text" id="loading-title-main-text">PREFERANS</span>
            </span>
            <span class="loading-title-pro-wrap">
              <span class="loading-title-pro">PRO</span>
              <span class="loading-title-pro-line" aria-hidden="true"></span>
            </span>
          </div>
        </div>
        <div class="loading-spinner" aria-hidden="true"></div>
        <div class="loading-status" id="loading-status">Loading game...</div>
      </div>
    </div>
    <canvas class="emscripten" id="canvas" oncontextmenu="event.preventDefault()"></canvas>
    <script type="text/javascript">
      function applyLoadingTitleLanguage() {
        var language = "english";
        try {
          language = localStorage.getItem("preferans_language")
            || localStorage.getItem("language")
            || "english";
        } catch (e) {
        }

        var title = "PREFERANS";
        if (language === "ukrainian") {
          title = "ПРЕФЕРАНС";
        } else if (language === "alternative") {
          title = "ПРЕФЕРАНС";
        }

        var shadow = document.getElementById("loading-title-main-shadow");
        var text = document.getElementById("loading-title-main-text");
        if (shadow) { shadow.textContent = title; }
        if (text) { text.textContent = title; }
      }

      function setLoadingStatus(text) {
        var status = document.getElementById("loading-status");
        if (status) {
          status.textContent = text || "Loading game...";
        }
      }

      function hideLoadingScreen() {
        document.body.classList.add("game-ready");
        window.setTimeout(function () {
          var loadingScreen = document.getElementById("loading-screen");
          if (loadingScreen) { loadingScreen.remove(); }
        }, 220);
      }

      applyLoadingTitleLanguage();

      var Module = {
        preRun: [],
        postRun: [hideLoadingScreen],
        print: (function () {
          return function (text) {
            text = Array.prototype.slice.call(arguments).join(" ");
            console.log(text);
          };
        })(),
        printErr: function (text) {
          text = Array.prototype.slice.call(arguments).join(" ");
          console.error(text);
        },
        canvas: (function () {
          var canvas = document.getElementById("canvas");
          let activeTouchId = null;
          let hoverClearHandle = null;
          const hoverClearDelayMs = 125;

          function emitMouse(type, touch) {
            canvas.dispatchEvent(new MouseEvent(type, {
              bubbles: true,
              cancelable: true,
              clientX: touch.clientX,
              clientY: touch.clientY,
              button: 0,
              buttons: type === "mouseup" ? 0 : 1,
            }));
          }

          function clearSyntheticHover() {
            hoverClearHandle = null;
            const rect = canvas.getBoundingClientRect();
            canvas.dispatchEvent(new MouseEvent("mousemove", {
              bubbles: true,
              cancelable: true,
              clientX: rect.left - 1,
              clientY: rect.top - 1,
              button: 0,
              buttons: 0,
            }));
          }

          function scheduleHoverClear() {
            if (hoverClearHandle !== null) { clearTimeout(hoverClearHandle); }
            hoverClearHandle = setTimeout(clearSyntheticHover, hoverClearDelayMs);
          }

          function activeTouch(touches) {
            if (activeTouchId === null) { return null; }
            return Array.from(touches).find(touch => touch.identifier === activeTouchId) ?? null;
          }

          function onTouch(event) {
            if (event.type === "touchstart") {
              if (hoverClearHandle !== null) {
                clearTimeout(hoverClearHandle);
                hoverClearHandle = null;
              }
              if (activeTouchId !== null || event.changedTouches.length === 0) { return; }
              activeTouchId = event.changedTouches[0].identifier;
            }

            const touch = activeTouch(event.changedTouches);
            if (!touch) {
              if (event.type === "touchcancel") { activeTouchId = null; }
              return;
            }

            emitMouse("mousemove", touch);
            if (event.type === "touchstart") { emitMouse("mousedown", touch); }
            if (event.type === "touchend" || event.type === "touchcancel") {
              emitMouse("mouseup", touch);
              scheduleHoverClear();
              activeTouchId = null;
            }
            event.preventDefault();
          }

          for (const type of ["touchstart", "touchmove", "touchend", "touchcancel"]) {
            canvas.addEventListener(type, onTouch, { passive: false });
          }

          return canvas;
        })(),
        setStatus: function (text) {
          setLoadingStatus(text);
          console.log("status: " + text);
        },
        monitorRunDependencies: function (left) {
          if (left > 0) {
            setLoadingStatus("Loading game... " + left + " step" + (left === 1 ? "" : "s") + " remaining");
          }
        },
        arguments: ["--url=@CMAKE_WEBSOCKET_URL@", "--language=english", "--color-scheme=dracula"],
      };
      window.onerror = function () {
        setLoadingStatus("Loading failed. Check the browser console.");
        console.log("onerror: " + event);
      };
    </script>
    {{{ SCRIPT }}}
  </body>
</html>
